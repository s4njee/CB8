{
  "name": "cb8",
  "productName": "CB8",
  "version": "1.0.0",
  "description": "CB8 — self-hosted comic and ebook reader (Fastify + SQLite)",
  "main": "dist/server/main.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "vite build --config vite.server.config.ts",
    "start": "node dist/server/main.cjs",
    "docker:build": "docker build -f docker/Dockerfile -t cb8-server ."
  },
  "license": "MIT",
  "author": "s4njee",
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/yauzl": "^2.10.3",
    "fast-check": "^3.23.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "@napi-rs/canvas": "^0.1.99",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "fastify": "^5.2.1",
    "node-unrar-js": "^2.0.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfjs-dist": "^5.6.205",
    "sharp": "^0.34.5",
    "yauzl": "^3.2.0"
  }
}
