{
  "name": "cb8",
  "productName": "CB8",
  "version": "1.0.4",
  "description": "CB8 comic + book reader: Electron shell hosting an embedded HTTP server and a vanilla-JS SPA frontend",
  "main": ".vite/build/index.js",
  "scripts": {
    "prestart": "node scripts/brand-dev-electron.mjs",
    "start": "electron-forge start",
    "start:headless": "electron-forge start -- --headless",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "prebuild:standalone": "pnpm build:renderer",
    "build:standalone": "node scripts/build-standalone.mjs",
    "start:standalone": "node dist/standalone.mjs"
  },
  "license": "MIT",
  "author": "s4njee",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.4.0",
    "@electron/rebuild": "^3.7.0",
    "@reforged/maker-appimage": "^5.2.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "electron": "^33.2.0",
    "fast-check": "^3.23.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "sharp"
    ]
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@jsquash/jxl": "^1.3.0",
    "@napi-rs/canvas": "^0.1.99",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.14",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.8",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "epubjs": "^0.3.93",
    "fastify": "^5.8.5",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "node-7z": "^3.0.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "yauzl": "^3.2.0",
    "zustand": "^5.0.13"
  }
}
