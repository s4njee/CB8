{
  "name": "cb8",
  "productName": "CB8",
  "version": "1.0.0",
  "description": "CB8 desktop comic book reader built with Electron, TypeScript, and React",
  "main": ".vite/build/index.js",
  "scripts": {
    "prestart": "node scripts/brand-dev-electron.mjs",
    "start": "electron-forge start",
    "start:headless": "electron-forge start -- --headless",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "license": "MIT",
  "author": "s4njee",
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/notarize": "^3.1.1",
    "@electron/osx-sign": "^2.4.0",
    "@electron/rebuild": "^3.7.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "fast-check": "^3.23.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "macos-alias",
      "sharp"
    ]
  },
  "dependencies": {
    "@jsquash/jxl": "^1.3.0",
    "@napi-rs/canvas": "^0.1.99",
    "@tanstack/react-virtual": "^3.11.2",
    "@tanstack/virtual-core": "^3.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "epubjs": "^0.3.93",
    "node-unrar-js": "^2.0.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "scheduler": "^0.27.0",
    "sharp": "^0.34.5",
    "yauzl": "^3.2.0"
  }
}
