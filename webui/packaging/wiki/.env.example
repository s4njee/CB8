# Wiki.js docker-compose configuration. Copy to `.env` and edit.
#   cp .env.example .env

# Password for Wiki.js's own Postgres role (used by both containers, so they
# always match). Pick a strong value.
WIKI_DB_PASSWORD=change-me

# Host port to publish the wiki on (Wiki.js listens on 3000 inside the container).
WIKI_PUBLISH_PORT=3000
