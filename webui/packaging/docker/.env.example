# CB8 docker-compose configuration.
#
# Fastest path — let the bootstrap script fill in the secrets for you:
#   ./cb8-init.sh        # writes .env with strong random CB8_DB_PASSWORD + secret
# Then edit the storage paths below and run `docker compose up -d`.
#
# Manual path — copy and edit by hand:
#   cp .env.example .env
#
# `docker compose` auto-loads `.env` from this directory. Keep the real `.env`
# out of version control — it holds secrets.

# --- Secrets ----------------------------------------------------------------

# Postgres password for the `cb8` role. Used by BOTH the postgres container and
# the DATABASE_URL the app/worker connect with, so they always match. Leave as
# `change-me` and run ./cb8-init.sh to auto-generate a strong value, or set one
# yourself. Changing it later means also resetting the role's password in the
# existing volume (or re-initializing it).
CB8_DB_PASSWORD=change-me

# Secret that signs better-auth sessions. OPTIONAL: if left empty, the server
# generates one on first boot and persists it in Postgres (app_meta), so single
# instances need not set it. Set it explicitly when running MULTIPLE replicas so
# every instance signs with the same key, or to control it yourself. ./cb8-init.sh
# fills it in for you. Keep it STABLE once set — rotating it logs everyone out.
BETTER_AUTH_SECRET=

# Extra origins the login system trusts, comma-separated. USUALLY UNNECESSARY:
# CB8 already trusts the address you browse to when it matches the request host
# (covers LAN IPs and .local names), and — with CB8_TRUST_PROXY_HEADERS=1 — the
# public URL behind a reverse proxy. Only list an origin here if a login is
# rejected as cross-site for an address CB8 cannot infer.
# e.g. http://192.168.1.248:4218,http://freya.local:4218
BETTER_AUTH_TRUSTED_ORIGINS=

# Set to 1 when CB8 runs behind a reverse proxy so it trusts the forwarded
# host/scheme (X-Forwarded-Host / X-Forwarded-Proto) and the public URL is
# accepted without listing it above. Leave unset for direct/LAN access.
# CB8_TRUST_PROXY_HEADERS=1

# --- Networking -------------------------------------------------------------

# Host port to publish the web UI on (container always listens on 8008).
CB8_PUBLISH_PORT=4218

# --- Image ------------------------------------------------------------------

# Image to run. Leave default to use a locally built `cb8:latest`, or point at a
# registry tag (e.g. registry.example.com/cb8:1857253) to pull a prebuilt image.
# CB8_IMAGE=cb8:latest

# --- Storage paths (host side) ---------------------------------------------

# Image cache + uploaded archives (regenerable/durable-ish; the catalog itself
# lives in Postgres). Shared by the API and worker containers.
CB8_DATA_PATH=/srv/cb8/data

# Comic and e-book libraries, mounted read-only into the containers.
CB8_COMICS_PATH=/mnt/raid6/comics
CB8_EBOOKS_PATH=/mnt/raid6/ebooks

# --- Tuning (optional) ------------------------------------------------------

# Parallel archive-open + thumbnailing. API default 4; worker default 8.
# CB8_INGEST_CONCURRENCY=4
# CB8_WORKER_INGEST_CONCURRENCY=8

# Per-archive listing timeout in ms (raise for very large/slow archives).
# CB8_ARCHIVE_LIST_TIMEOUT_MS=60000
